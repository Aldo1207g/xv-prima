---
---
<section class="py-16 px-8 bg-[#fdfbf7] text-center overflow-hidden">
  <!-- Título con líneas laterales -->
  <div class="flex items-center justify-center gap-4 mb-14">
    <div class="h-[1px] w-12 bg-[#c5a059]/50"></div>
    <h2 class="font-serif text-4xl italic text-[#c5a059]">Itinerario</h2>
    <div class="h-[1px] w-12 bg-[#c5a059]/50"></div>
  </div>
  
  <div class="relative max-w-xs mx-auto">
    <!-- Línea vertical de fondo -->
    <div class="absolute left-8 top-4 bottom-4 w-0.5 bg-[#e6d5a1]/50"></div>

    <!-- 6:30 PM - Recepción -->
    <div class="relative flex items-center mb-10">
      <div class="w-16 h-16 bg-[#c5a059] rounded-full border-4 border-[#fdfbf7] z-10 flex-shrink-0 flex items-center justify-center shadow-md">
        <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2-2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m3-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
      </div>
      <div class="ml-6 text-left">
        <p class="text-sm font-sans tracking-widest text-gray-600 mb-1">6:30 PM</p>
        <h3 class="font-serif text-lg uppercase tracking-wider text-coquette-dark">Recepción</h3>
      </div>
    </div>

    <!-- 7:00 PM - Inicio -->
    <div class="relative flex items-center mb-10">
      <div class="w-16 h-16 bg-[#c5a059] rounded-full border-4 border-[#fdfbf7] z-10 flex-shrink-0 flex items-center justify-center shadow-md">
        <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
        </svg>
      </div>
      <div class="ml-6 text-left">
        <p class="text-sm font-sans tracking-widest text-gray-600 mb-1">7:00 PM</p>
        <h3 class="font-serif text-lg uppercase tracking-wider text-coquette-dark">Inicio del evento</h3>
      </div>
    </div>

    <!-- 8:00 PM - Cena -->
    <div class="relative flex items-center mb-10">
      <div class="w-16 h-16 bg-[#c5a059] rounded-full border-4 border-[#fdfbf7] z-10 flex-shrink-0 flex items-center justify-center shadow-md">
        <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
      </div>
      <div class="ml-6 text-left">
        <p class="text-sm font-sans tracking-widest text-gray-600 mb-1">8:00 PM</p>
        <h3 class="font-serif text-lg uppercase tracking-wider text-coquette-dark">Cena</h3>
      </div>
    </div>

    <!-- 8:45 PM - Brindis -->
    <div class="relative flex items-center mb-10">
      <div class="w-16 h-16 bg-[#c5a059] rounded-full border-4 border-[#fdfbf7] z-10 flex-shrink-0 flex items-center justify-center shadow-md">
        <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4m5-5l5 5 5-5M12 21v-5" />
        </svg>
      </div>
      <div class="ml-6 text-left">
        <p class="text-sm font-sans tracking-widest text-gray-600 mb-1">8:45 PM</p>
        <h3 class="font-serif text-lg uppercase tracking-wider text-coquette-dark">Brindis</h3>
      </div>
    </div>

    <!-- 9:00 PM - Vals -->
    <div class="relative flex items-center mb-10">
      <div class="w-16 h-16 bg-[#c5a059] rounded-full border-4 border-[#fdfbf7] z-10 flex-shrink-0 flex items-center justify-center shadow-md">
        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
      </div>
      <div class="ml-6 text-left">
        <p class="text-sm font-sans tracking-widest text-gray-600 mb-1">9:00 PM</p>
        <h3 class="font-serif text-lg uppercase tracking-wider text-coquette-dark">Vals</h3>
      </div>
    </div>

    <!-- 1:00 AM - Fin -->
    <div class="relative flex items-center">
      <div class="w-16 h-16 bg-[#c5a059] rounded-full border-4 border-[#fdfbf7] z-10 flex-shrink-0 flex items-center justify-center shadow-md">
        <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </div>
      <div class="ml-6 text-left">
        <p class="text-sm font-sans tracking-widest text-gray-600 mb-1">1:00 AM</p>
        <h3 class="font-serif text-lg uppercase tracking-wider text-coquette-dark">Fin del evento</h3>
      </div>
    </div>

  </div>
</section>